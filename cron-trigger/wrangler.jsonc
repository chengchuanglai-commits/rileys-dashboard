{
  // Cloudflare Worker —— 准点触发 GitHub trading-signals 工作流
  // 解决 GitHub schedule 延迟数小时/丢运行的问题（Cloudflare cron 秒级准点）
  "name": "rileys-signal-cron",
  "main": "src/index.js",
  "compatibility_date": "2026-01-01",
  "triggers": {
    // 11:30→trading-signals(主信号) ; 12:00→deepseek-broad(广撒) ; 12:30→multifactor-bq(更新allocation,IBKR自检靠它)
    "crons": ["30 11 * * 1-5", "0 12 * * 1-5", "30 12 * * 1-5"]
  }
}
